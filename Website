<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nexa Buildworks</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–gold: #C9A84C;
–gold-light: #E8C97A;
–gold-dim: #8B6F2E;
–black: #0A0A0A;
–black-2: #111111;
–black-3: #1A1A1A;
–white: #F5F0E8;
}

html { scroll-behavior: smooth; background: #0A0A0A; }

body {
background: #0A0A0A !important;
background-color: #0A0A0A !important;
color: #F5F0E8 !important;
font-family: Arial, Helvetica, sans-serif;
overflow-x: hidden;
}

nav {
position: fixed;
top: 0; width: 100%;
z-index: 100;
display: flex;
align-items: center;
justify-content: space-between;
padding: 1.2rem 4rem;
background: rgba(10,10,10,0.93);
backdrop-filter: blur(12px);
border-bottom: 1px solid rgba(201,168,76,0.2);
}

.nav-logo { display: flex; align-items: center; gap: 0.8rem; }
.nav-logo svg { width: 36px; height: 36px; }

.nav-brand {
font-weight: 700;
font-size: 1.05rem;
letter-spacing: 0.25em;
color: var(–gold);
}

.nav-brand span {
display: block;
font-weight: 400;
font-size: 0.58rem;
letter-spacing: 0.4em;
color: rgba(201,168,76,0.5);
margin-top: 1px;
}

.nav-abn {
display: block;
font-weight: 400;
font-size: 0.48rem;
letter-spacing: 0.2em;
color: rgba(201,168,76,0.3);
margin-top: 1px;
}

.nav-links { display: flex; gap: 2.5rem; list-style: none; align-items: center; }

.nav-links a {
color: rgba(245,240,232,0.6);
text-decoration: none;
font-size: 0.7rem;
letter-spacing: 0.18em;
text-transform: uppercase;
transition: color 0.3s;
}

.nav-links a:hover { color: var(–gold); }

.nav-cta {
border: 1px solid var(–gold) !important;
color: var(–gold) !important;
padding: 0.45rem 1.3rem !important;
}

.nav-cta:hover { background: var(–gold) !important; color: var(–black) !important; }

/* HERO */
.hero {
min-height: 100vh;
display: flex;
align-items: center;
position: relative;
overflow: hidden;
padding: 9rem 4rem 5rem;
}

.hero-bg {
position: absolute; inset: 0;
background:
radial-gradient(ellipse 60% 60% at 80% 50%, rgba(201,168,76,0.07) 0%, transparent 70%),
radial-gradient(ellipse 40% 40% at 20% 80%, rgba(201,168,76,0.04) 0%, transparent 60%);
}

.hero-grid {
position: absolute; inset: 0;
background-image:
linear-gradient(rgba(201,168,76,0.04) 1px, transparent 1px),
linear-gradient(90deg, rgba(201,168,76,0.04) 1px, transparent 1px);
background-size: 60px 60px;
}

.hero-content {
position: relative;
max-width: 1200px;
width: 100%; margin: 0 auto;
display: grid;
grid-template-columns: 1fr 1fr;
gap: 4rem;
align-items: center;
}

.hero-tag {
font-size: 0.63rem;
letter-spacing: 0.4em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 1.5rem;
display: flex; align-items: center; gap: 1rem;
animation: fadeUp 0.8s 0.2s both;
}

.hero-tag::before {
content: ‘’;
display: block;
width: 40px; height: 1px;
background: var(–gold);
}

h1.hero-title {
font-family: Georgia, ‘Times New Roman’, serif;
font-size: clamp(3rem, 6.5vw, 5.8rem);
font-weight: 400;
line-height: 1;
color: #F5F0E8;
animation: fadeUp 0.8s 0.4s both;
}

h1.hero-title strong {
font-weight: 700;
color: var(–gold);
display: block;
}

.hero-sub {
margin-top: 1.8rem;
font-size: 0.92rem;
color: rgba(245,240,232,0.55);
line-height: 1.8;
max-width: 440px;
animation: fadeUp 0.8s 0.6s both;
}

.hero-badge {
margin-top: 1.2rem;
display: inline-flex;
align-items: center;
gap: 0.6rem;
font-size: 0.68rem;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–gold);
border: 1px solid rgba(201,168,76,0.35);
padding: 0.5rem 1rem;
animation: fadeUp 0.8s 0.7s both;
}

.hero-badge svg { width: 13px; height: 13px; }

.hero-actions {
margin-top: 2.5rem;
display: flex; gap: 1.5rem; align-items: center;
animation: fadeUp 0.8s 0.85s both;
}

.btn-gold {
background: var(–gold);
color: var(–black);
padding: 0.9rem 2.2rem;
font-size: 0.7rem;
font-weight: 700;
letter-spacing: 0.18em;
text-transform: uppercase;
border: none; cursor: pointer;
transition: all 0.3s;
text-decoration: none;
display: inline-block;
}

.btn-gold:hover { background: var(–gold-light); transform: translateY(-2px); }

.btn-outline {
color: #F5F0E8;
font-size: 0.68rem;
letter-spacing: 0.18em;
text-transform: uppercase;
font-weight: 600;
text-decoration: none;
display: flex; align-items: center; gap: 0.5rem;
transition: color 0.3s;
}

.btn-outline:hover { color: var(–gold); }
.btn-outline::after { content: ‘→’; transition: transform 0.3s; }
.btn-outline:hover::after { transform: translateX(4px); }

.hero-right {
display: flex;
justify-content: center; align-items: center;
animation: fadeIn 1.2s 0.5s both;
}

/* STATS */
.stats-bar {
background: var(–black-3);
border-top: 1px solid rgba(201,168,76,0.12);
border-bottom: 1px solid rgba(201,168,76,0.12);
padding: 2rem 4rem;
}

.stats-inner {
max-width: 1200px; margin: 0 auto;
display: flex;
justify-content: space-between; align-items: center;
}

.stat { text-align: center; }

.stat-num {
font-family: Georgia, serif;
font-size: 2.7rem;
font-weight: 700;
color: var(–gold);
line-height: 1;
}

.stat-lbl {
font-size: 0.6rem;
letter-spacing: 0.2em;
color: rgba(245,240,232,0.4);
text-transform: uppercase;
margin-top: 0.4rem;
}

.divider { width: 1px; height: 48px; background: rgba(201,168,76,0.18); }

/* VIC BANNER */
.vic-banner {
background: rgba(201,168,76,0.05);
border-bottom: 1px solid rgba(201,168,76,0.14);
padding: 1.3rem 4rem;
}

.vic-inner {
max-width: 1200px; margin: 0 auto;
display: flex; align-items: center; justify-content: center;
gap: 0.9rem;
}

.vic-inner svg { color: var(–gold); width: 19px; height: 19px; flex-shrink: 0; }

.vic-text {
font-size: 0.75rem;
letter-spacing: 0.13em;
text-transform: uppercase;
color: var(–gold);
font-weight: 700;
}

.vic-text span {
color: rgba(245,240,232,0.55);
font-weight: 400;
text-transform: none;
letter-spacing: 0.04em;
margin-left: 0.5rem;
}

/* SERVICES */
.services { padding: 8rem 4rem; max-width: 1200px; margin: 0 auto; }

.sec-hdr { margin-bottom: 4rem; }

.sec-tag {
font-size: 0.6rem;
letter-spacing: 0.4em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 1rem;
display: flex; align-items: center; gap: 1rem;
}

.sec-tag::before { content: ‘’; display: block; width: 30px; height: 1px; background: var(–gold); }

h2.sec-title {
font-family: Georgia, serif;
font-size: clamp(2.2rem, 4.5vw, 3.8rem);
font-weight: 400;
line-height: 1.1;
color: #F5F0E8;
}

h2.sec-title strong { font-weight: 700; color: var(–gold); }

.grid-svc {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 1px;
background: rgba(201,168,76,0.1);
border: 1px solid rgba(201,168,76,0.1);
}

/* SERVICE CARD */
.svc-card {
background: var(–black-2);
background-size: cover;
background-position: center;
position: relative; overflow: hidden;
transition: background 0.4s;
display: flex;
flex-direction: column;
}

/* Dark overlay so text is always readable over photo */
.svc-card::before {
content: ‘’;
position: absolute; inset: 0;
background: rgba(0,0,0,0.72);
transition: background 0.4s;
z-index: 0;
}

.svc-card:hover::before { background: rgba(0,0,0,0.55); }

.svc-card::after {
content: ‘’;
position: absolute;
bottom: 0; left: 0;
width: 100%; height: 2px;
background: var(–gold);
transform: scaleX(0);
transform-origin: left;
transition: transform 0.4s;
z-index: 1;
}

.svc-card:hover::after { transform: scaleX(1); }

/* Photo strip */
.svc-photos {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 2px;
height: 120px;
overflow: hidden;
position: relative;
}

.svc-photos img {
width: 100%;
height: 100%;
object-fit: cover;
display: block;
filter: brightness(0.7) saturate(0.8);
transition: filter 0.4s, transform 0.5s;
}

.svc-card:hover .svc-photos img {
filter: brightness(0.9) saturate(1);
transform: scale(1.04);
}

.svc-photos-hint {
position: absolute;
bottom: 6px; right: 8px;
font-size: 0.52rem;
letter-spacing: 0.12em;
text-transform: uppercase;
color: rgba(201,168,76,0.85);
background: rgba(0,0,0,0.55);
padding: 0.2rem 0.5rem;
border: 1px solid rgba(201,168,76,0.25);
}

.svc-body { padding: 2rem 2.2rem 2.2rem; flex: 1; position: relative; z-index: 1; }

.svc-num {
font-family: Georgia, serif;
font-size: 3rem;
font-weight: 700;
color: rgba(201,168,76,0.07);
line-height: 1;
margin-bottom: 1rem;
}

.svc-icon { width: 34px; height: 34px; margin-bottom: 0.9rem; color: var(–gold); }

.svc-name {
font-size: 0.88rem;
font-weight: 700;
letter-spacing: 0.08em;
text-transform: uppercase;
color: #F5F0E8;
margin-bottom: 0.7rem;
}

.svc-desc { font-size: 0.8rem; color: rgba(245,240,232,0.45); line-height: 1.75; }

.svc-gallery-hint {
display: inline-block;
margin-top: 1rem;
font-size: 0.62rem;
letter-spacing: 0.12em;
text-transform: uppercase;
color: rgba(201,168,76,0.5);
}

/* CTA card - no photos */
.svc-card-cta {
display: flex;
align-items: center;
justify-content: center;
text-align: center;
padding: 3rem 2rem;
background: linear-gradient(135deg, #1A1500 0%, #2A1F00 50%, #1A1500 100%) !important;
background-size: cover !important;
cursor: default;
border: 1px solid rgba(201,168,76,0.3) !important;
}
.svc-card-cta::before { background: rgba(0,0,0,0.1) !important; }
.svc-card-cta::after { display: none; }

/* ABOUT */
.about {
padding: 8rem 4rem;
background: var(–black-3);
border-top: 1px solid rgba(201,168,76,0.08);
border-bottom: 1px solid rgba(201,168,76,0.08);
}

.about-inner {
max-width: 1200px; margin: 0 auto;
display: grid;
grid-template-columns: 1fr 1fr;
gap: 6rem; align-items: center;
}

.about-body p {
font-size: 0.88rem;
color: rgba(245,240,232,0.55);
line-height: 1.9;
margin-bottom: 1.3rem;
}

.about-body p strong { color: var(–gold); }

.quote-box {
border: 1px solid rgba(201,168,76,0.25);
padding: 2.8rem;
position: relative;
}

.quote-box::before {
content: ‘’;
position: absolute;
top: -7px; left: -7px; right: 7px; bottom: 7px;
border: 1px solid rgba(201,168,76,0.08);
pointer-events: none;
}

.quote-text {
font-family: Georgia, serif;
font-size: 1.4rem;
font-weight: 400;
line-height: 1.55;
color: #F5F0E8;
font-style: italic;
}

.quote-text strong { font-weight: 700; color: var(–gold); font-style: normal; }

.quote-sig {
margin-top: 1.8rem;
font-size: 0.6rem;
letter-spacing: 0.3em;
text-transform: uppercase;
color: rgba(201,168,76,0.5);
display: flex; align-items: center; gap: 1rem;
}

.quote-sig::before { content: ‘’; display: block; width: 28px; height: 1px; background: rgba(201,168,76,0.3); }

/* CONTACT */
.contact { padding: 8rem 4rem; max-width: 1200px; margin: 0 auto; }

.contact-inner {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 5rem; align-items: start;
}

.cinfo { display: flex; flex-direction: column; gap: 2.5rem; }

.citem { display: flex; gap: 1.4rem; align-items: flex-start; }

.cicon {
width: 44px; height: 44px;
border: 1px solid rgba(201,168,76,0.3);
display: flex; align-items: center; justify-content: center;
flex-shrink: 0; color: var(–gold);
}

.cicon svg { width: 18px; height: 18px; }

.clabel {
font-size: 0.57rem;
letter-spacing: 0.3em;
text-transform: uppercase;
color: var(–gold-dim);
margin-bottom: 0.35rem;
}

.cval {
font-size: 0.95rem;
color: #F5F0E8;
font-weight: 600;
line-height: 1.7;
}

.cval a { color: #F5F0E8; text-decoration: none; transition: color 0.3s; }
.cval a:hover { color: var(–gold); }

.cov-box {
display: flex; gap: 0.9rem; align-items: flex-start;
background: rgba(201,168,76,0.06);
border: 1px solid rgba(201,168,76,0.2);
padding: 1.1rem 1.3rem;
}

.cov-box svg { width: 18px; height: 18px; color: var(–gold); flex-shrink: 0; margin-top: 2px; }

.cov-box p { font-size: 0.78rem; color: #D0C9BC; line-height: 1.6; }
.cov-box p strong { color: var(–gold); display: block; font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.2rem; }

.cform { display: flex; flex-direction: column; gap: 1.1rem; }

.fgrp { display: flex; flex-direction: column; gap: 0.45rem; }

.fgrp label {
font-size: 0.57rem;
letter-spacing: 0.3em;
text-transform: uppercase;
color: rgba(201,168,76,0.6);
}

.fgrp input, .fgrp textarea {
background: rgba(201,168,76,0.03);
border: 1px solid rgba(201,168,76,0.18);
color: #F5F0E8;
padding: 0.85rem 1.1rem;
font-family: Arial, sans-serif;
font-size: 0.88rem;
transition: border-color 0.3s;
outline: none; width: 100%;
}

.fgrp input:focus, .fgrp textarea:focus { border-color: rgba(201,168,76,0.55); }
.fgrp textarea { resize: vertical; min-height: 110px; }
.fgrp input::placeholder, .fgrp textarea::placeholder { color: rgba(245,240,232,0.2); }

.fsub {
background: var(–gold);
color: var(–black);
border: none;
padding: 0.9rem 2.2rem;
font-family: Arial, sans-serif;
font-size: 0.7rem;
font-weight: 700;
letter-spacing: 0.18em;
text-transform: uppercase;
cursor: pointer;
transition: all 0.3s;
align-self: flex-start;
margin-top: 0.5rem;
}

.fsub:hover { background: var(–gold-light); transform: translateY(-2px); }

.insta-btn {
display: flex;
align-items: center;
gap: 0.8rem;
background: linear-gradient(135deg, rgba(131,58,180,0.15), rgba(253,29,29,0.1), rgba(252,176,69,0.15));
border: 1px solid rgba(201,168,76,0.3);
padding: 1rem 1.3rem;
text-decoration: none;
transition: all 0.3s;
color: #F5F0E8;
}
.insta-btn:hover { border-color: var(–gold); background: linear-gradient(135deg, rgba(131,58,180,0.25), rgba(253,29,29,0.18), rgba(252,176,69,0.25)); }
.insta-btn svg { color: var(–gold); flex-shrink: 0; }
.insta-btn { font-size: 0.82rem; font-weight: 600; letter-spacing: 0.05em; }
.insta-btn span { font-size: 0.65rem; color: rgba(201,168,76,0.6); letter-spacing: 0.1em; margin-left: auto; }

/* FOOTER */
footer {
background: #060606;
border-top: 1px solid rgba(201,168,76,0.12);
padding: 2.5rem 4rem;
display: flex; align-items: center; justify-content: space-between;
}

.fbrand { display: flex; align-items: center; gap: 0.8rem; }
.fbrand svg { width: 28px; height: 28px; }
.fbrand-info { display: flex; flex-direction: column; gap: 3px; }
.fbrand-name { font-size: 0.85rem; font-weight: 700; letter-spacing: 0.25em; color: var(–gold); }
.fbrand-abn { font-size: 0.52rem; letter-spacing: 0.15em; color: rgba(201,168,76,0.4); }
.fbrand-email { font-size: 0.6rem; color: rgba(201,168,76,0.55); text-decoration: none; }
.fbrand-email:hover { color: var(–gold); }

.fcopy { font-size: 0.6rem; letter-spacing: 0.12em; color: rgba(245,240,232,0.2); text-transform: uppercase; }

.flinks { display: flex; gap: 2rem; list-style: none; }
.flinks a { font-size: 0.6rem; letter-spacing: 0.15em; color: rgba(245,240,232,0.3); text-decoration: none; text-transform: uppercase; transition: color 0.3s; }
.flinks a:hover { color: var(–gold); }

/* GALLERY MODAL */
.modal-overlay {
display: none;
position: fixed; inset: 0;
background: rgba(0,0,0,0.93);
z-index: 1000;
align-items: center;
justify-content: center;
padding: 1.5rem;
}
.modal-overlay.open { display: flex; }

.modal-box {
background: #111;
border: 1px solid rgba(201,168,76,0.25);
max-width: 880px; width: 100%;
max-height: 90vh;
overflow-y: auto;
position: relative;
}

.modal-top {
display: flex; align-items: center; justify-content: space-between;
padding: 1.2rem 1.5rem;
border-bottom: 1px solid rgba(201,168,76,0.15);
position: sticky; top: 0; background: #111; z-index: 5;
}

.modal-title { font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(–gold); font-weight: 700; }

.modal-close {
background: none; border: none;
color: rgba(245,240,232,0.5);
font-size: 1.6rem;
cursor: pointer; line-height: 1;
transition: color 0.2s;
}
.modal-close:hover { color: var(–gold); }

.modal-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
gap: 3px; padding: 3px;
}

.modal-img {
width: 100%; aspect-ratio: 4/3;
object-fit: cover; display: block;
cursor: zoom-in;
transition: opacity 0.3s;
}
.modal-img:hover { opacity: 0.82; }

.modal-caption {
padding: 1rem 1.5rem;
font-size: 0.68rem; color: rgba(245,240,232,0.35);
border-top: 1px solid rgba(201,168,76,0.1);
letter-spacing: 0.05em;
}

/* FULLSCREEN */
.fullscreen {
display: none;
position: fixed; inset: 0;
background: rgba(0,0,0,0.97);
z-index: 1100;
align-items: center; justify-content: center;
cursor: zoom-out;
}
.fullscreen.open { display: flex; }
.fullscreen img { max-width: 95vw; max-height: 90vh; object-fit: contain; }

@keyframes fadeUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

@media (max-width: 900px) {
nav { padding: 1rem 1.5rem; }
.nav-links { display: none; }
.hero { padding: 7rem 1.5rem 4rem; }
.hero-content { grid-template-columns: 1fr; }
.hero-right { display: none; }
.stats-bar, .vic-banner { padding: 1.5rem; }
.stats-inner { flex-wrap: wrap; gap: 1.5rem; justify-content: center; }
.divider { display: none; }
.services { padding: 4rem 1.5rem; }
.grid-svc { grid-template-columns: 1fr; }
.svc-photos { height: 160px; }
.about { padding: 4rem 1.5rem; }
.about-inner { grid-template-columns: 1fr; gap: 3rem; }
.contact { padding: 4rem 1.5rem; }
.contact-inner { grid-template-columns: 1fr; gap: 3rem; }
footer { padding: 2rem 1.5rem; flex-direction: column; gap: 1.5rem; text-align: center; align-items: center; }
.modal-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>

</head>
<body>

<!-- NAV -->

<nav>
  <div class="nav-logo">
    <svg viewBox="0 0 60 60" fill="none">
      <rect x="2" y="2" width="56" height="56" stroke="#C9A84C" stroke-width="2"/>
      <path d="M30 8 L52 30 L30 30" stroke="#C9A84C" stroke-width="2" fill="none"/>
      <path d="M30 8 L8 30 L30 30" stroke="#C9A84C" stroke-width="2" fill="none"/>
      <line x1="20" y1="30" x2="20" y2="52" stroke="#C9A84C" stroke-width="2"/>
      <line x1="30" y1="30" x2="30" y2="52" stroke="#C9A84C" stroke-width="2"/>
      <line x1="40" y1="30" x2="40" y2="52" stroke="#C9A84C" stroke-width="2"/>
    </svg>
    <div class="nav-brand">NEXA
      <span>BUILDWORKS</span>
      <span class="nav-abn">ABN 93 690 391 550</span>
    </div>
  </div>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
    <li>
      <a href="https://www.instagram.com/nexa.buildworks?igsh=eXBzd3BsMXZ4bW1o&utm_source=qr" target="_blank" style="display:flex;align-items:center;gap:0.4rem;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
